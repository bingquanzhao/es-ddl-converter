{
  "logs": {
    "mappings": {
      "dynamic": "true",
      "properties": {
        "@timestamp": { "type": "date" },
        "level": { "type": "keyword" },
        "message": { "type": "text", "analyzer": "standard" }
      }
    }
  },
  "users": {
    "mappings": {
      "properties": {
        "name": { "type": "keyword" },
        "email": { "type": "keyword" },
        "age": { "type": "integer" },
        "active": { "type": "boolean" }
      }
    }
  },
  "events": {
    "mappings": {
      "properties": {
        "event_time": { "type": "date", "format": "epoch_millis" },
        "event_type": { "type": "keyword" },
        "payload": { "type": "object", "enabled": false }
      }
    }
  },
  ".kibana": {
    "mappings": {
      "properties": {
        "type": { "type": "keyword" }
      }
    }
  }
}
